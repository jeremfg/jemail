{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JEMAIL Global Settings",
  "description": "Schema for validating and documenting JEMAIL global settings YAML files.",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "description": "Whether JEMAIL is enabled"
    },
    "log_level": {
      "type": "string",
      "description": "Log level",
      "enum": [
        "CRITICAL",
        "FATAL",
        "ERROR",
        "WARN",
        "WARNING",
        "INFO",
        "DEBUG",
        "NOTSET"
      ]
    },
    "sync": {
      "type": "object",
      "description": "Sync options",
      "properties": {
        "batch_size": {
          "type": "integer",
          "description": "Max emails to fetch per account per sync (0 = unlimited)"
        },
        "retention_days": {
          "type": "integer",
          "description": "Days to keep on server before archiving (0 = keep all)"
        },
        "deduplicate": {
          "type": "boolean",
          "description": "Deduplicate by message-id across accounts"
        }
      }
    },
    "discord": {
      "type": "object",
      "description": "Discord integration settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to enable Discord interactions"
        },
        "secret": {
          "type": "string",
          "description": "Discord OAuth2 Client Secret",
          "$comment": "Visit Discord's Developer Portal, the section about OAuth2 under your application."
        }
      },
      "required": ["enabled", "secret"]
    },
    "entraID": {
      "type": "object",
      "description": "Microsoft Entra ID integration settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to enable Microsoft Entra ID authentication"
        },
        "id": {
          "type": "string",
          "description": "Application (client) ID",
          "$comment": "This is the ID identifying your registered application"
        },
        "secret": {
          "type": "string",
          "description": "Application Credentials (client secret)",
          "$comment": "The secret to be used when authenticating with Microsoft Entra ID. Visit the Entra ID portal, the section about Certificates & secrets under your registered application."
        }
      },
      "required": ["enabled", "id", "secret"]
    }
  }
}
